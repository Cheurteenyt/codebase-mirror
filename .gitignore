# Dependencies
node_modules/

# Build artifacts
dist/
*.tsbuildinfo
# TypeScript-compiled .js files in graph-ui/src (source is .tsx/.ts; Vite handles bundling)
graph-ui/src/**/*.js
graph-ui/src/**/*.js.map

# Lockfiles (we use npm install, not npm ci, to avoid platform-specific lockfiles)
package-lock.json

# Test artifacts
coverage/

# Runtime
*.log
.DS_Store
Thumbs.db

# Local DBs (never commit)
*.human.db
*.human.db-*
*.db
*.db-*
*.db.zst

# Backups
*.bak
*.bak.*

# IDE
.idea/
.vscode/
*.swp

# Local config overrides
.codebase-memory.local.json

{
  "name": "codebase-memory-v2",
  "version": "0.78.0-alpha.1",
  "packageManager": "npm@10.9.0",
  "description": "Codebase Memory V2 — hybrid code intelligence (native WASM indexer + human memory graph + Obsidian sync)",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "cbm-v2": "dist/cli/index.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:check": "node --test ../scripts/docs/validate-docs.test.mjs ../scripts/benchmark/v1-v2-truth-audit/derive-structural-references.test.mjs ../scripts/benchmark/v1-v2-truth-audit/checkpoint.test.mjs && node ../scripts/docs/validate-docs.mjs && node ../scripts/benchmark/v1-v2-truth-audit/verify-spec.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.graph-ui-lab.json --noEmit",
    "prepublishOnly": "npm run typecheck && npm test",
    "bench:incremental": "tsx scripts/incremental-benchmark-r87.ts",
    "bench:incremental:smoke": "tsx scripts/incremental-benchmark-r87.ts --smoke",
    "bench:precision": "tsx scripts/precision-benchmark-r112.ts --project precision-bench --root ./src --sample 50",
    "bench:tokens": "tsx scripts/token-payload-benchmark.ts",
    "bench:graph-ui": "node scripts/graph-ui-runtime-benchmark.mjs",
    "bench:graph-ui:compare": "tsx scripts/graph-ui-comparison-lab.ts",
    "smoke:graph-ui:browser": "tsx scripts/graph-ui-browser-smoke.ts",
    "build:backend": "npm run clean && tsc -p tsconfig.json",
    "build:package": "node scripts/build-package.mjs",
    "prepack": "npm run build:package",
    "bench:publication": "tsx scripts/publication-benchmark-r169b.ts",
    "bench:publication:smoke": "tsx scripts/publication-benchmark-r169b.ts --smoke"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "ts-morph": "^28.0.0",
    "tree-sitter-wasm": "^1.1.2",
    "typescript": "^5.7.2",
    "web-tree-sitter": "^0.26.10",
    "ws": "^8.21.0",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/ws": "^8.18.1",
    "playwright-core": "^1.61.1",
    "tsx": "^4.19.1",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10 <12"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cheurteenyt/Ariad.git",
    "directory": "v2"
  },
  "homepage": "https://github.com/Cheurteenyt/Ariad#readme",
  "bugs": {
    "url": "https://github.com/Cheurteenyt/Ariad/issues"
  },
  "keywords": [
    "codebase",
    "memory",
    "mcp",
    "indexer",
    "wasm",
    "tree-sitter",
    "obsidian",
    "graph"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}

{
  "name": "codebase-memory-v2",
  "version": "0.5.5",
  "description": "Codebase Memory V2 sidecar \u2014 human memory graph + Obsidian sync",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "cbm-v2": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
